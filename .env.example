# =============================================================================
# VSVV Premium Broker — Environment Variables
# =============================================================================
# KOPIERE dieses File zu .env und fülle alle Werte mit DEINEN Secrets aus.
# NIEMALS Secrets in dieses File schreiben — es ist im Repo öffentlich!
# Production-Secrets gehören in ein sicheres Secrets-Management (z.B. HashiCorp Vault, GitHub Secrets)
# =============================================================================

# Database
DB_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD

# Redis (optional, for queues)
REDIS_URL=redis://localhost:6379

# JWT — GENERATE WITH: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_TO_A_SECURE_64_CHAR_HEX_SECRET
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# S3-compatible Storage (Exoscale SOS / MinIO)
# ---------------------------------------------------------------------
# Production (Exoscale SOS):
#   S3_ENDPOINT=https://sos-ch-dk-2.exo.io
#   S3_REGION=ch-dk-2
#   S3_BUCKET=vsvv-permium-broker-app-documentuploads
#   S3_ACCESS_KEY_ID=EXO_DEIN_KEY
#   S3_SECRET_ACCESS_KEY=DEIN_SECRET
#
# Local development (MinIO Docker):
#   MINIO_ENDPOINT=localhost
#   MINIO_PORT=9000
#   MINIO_USE_SSL=false
#   MINIO_ACCESS_KEY=minioadmin
#   MINIO_SECRET_KEY=CHANGE_ME_TO_A_SECURE_PASSWORD
#   MINIO_BUCKET=vsvv-documents
#
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_TO_A_SECURE_PASSWORD
MINIO_BUCKET=vsvv-documents

# SMTP (MailHog for dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@vsvv.ch

# Backend
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
# SECURITY: In production set this to the explicit frontend URL (e.g. https://app.vsvv.ch)
CORS_ORIGIN=http://localhost:3004
LOG_LEVEL=debug
