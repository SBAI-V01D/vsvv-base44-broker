# =============================================================================
# avaSysAIByNik Backend — Beispiel-Umgebungsvariablen
# =============================================================================
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
#
# Exoscale SOS (Production) oder MinIO (lokale Dev):
#   - Für Exoscale: S3_ENDPOINT, S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY setze
#   - Für MinIO:     MINIO_ENDPOINT, MINIO_ACCESS_KEY, MINIO_SECRET_KEY setze
# =============================================================================

# ----- Server -----
PORT=3003
HOST=0.0.0.0
NODE_ENV=development

# ----- Datenbank -----
DATABASE_URL=postgresql://avasys:avasys_dev_2026@localhost:5432/avasys

# ----- JWT -----
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ----- SMTP -----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@avasys.ch
SMTP_USER=
SMTP_PASS=

# ----- CORS -----
# Kommaseparierti Liste vo erlaubte Origins.
# Dev: Default = http://localhost:3004 (weglassen = Default)
# Prod: https://app.avasys.ch
# CORS_ORIGIN=http://localhost:3004

# ----- Logging -----
LOG_LEVEL=debug

# ----- S3 / Object Storage (Exoscale SOS) -----
# Production: Exoscale SOS (S3-kompatibel)
# S3_ENDPOINT=https://sos-ch-dk-2.exo.io
# S3_REGION=ch-dk-2
# S3_BUCKET=avasys-premium-broker-app-documentuploads
# S3_ACCESS_KEY_ID=EXO...
# S3_SECRET_ACCESS_KEY=...

# ----- S3 / Object Storage (MinIO, lokale Dev) -----
# Fallback wenn S3_ENDPOINT nöd gsetzt isch
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=avasys-documents
