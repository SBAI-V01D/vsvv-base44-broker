// ============================================================================
// MODELS
// ============================================================================

// --------------------------------------------------------------------------
// 1. Organization
// --------------------------------------------------------------------------
model Organization {
  id                      String           @id @default(uuid())
  name                    String
  type                    OrganizationType @default(broker)
  status                  String           @default("active")
  finma_number            String?
  street                  String?
  zip_code                String?
  city                    String?
  phone                   String?
  email                   String?
  website                 String?
  works_with_address_brokers Boolean        @default(false)
  notes                   String?
  created_at              DateTime         @default(now())
  updated_at              DateTime         @updatedAt
  archived                Boolean          @default(false)
  archived_at             DateTime?
  archived_by             String?

  // Relations
  users                   User[]
  advisors                Advisor[]
  customers               Customer[]
  contracts               Contract[]
  applications            Application[]
  commissions             Commission[]
  documents               Document[]
  tasks                   Task[]
  leads                   Lead[]
  notifications           Notification[]
  messages                Message[]
  status_definitions      StatusDefinition[]
  status_histories        StatusHistory[]
  accounting_entries      AccountingEntry[]
  payouts                 Payout[]
  finance_periods         FinancePeriod[]
  bag_praemien_daten      BAGPraemienDaten[]
  krankenkassen_vergleiche KrankenkassenVergleich[]
  vergleichs_analysen     VergleichsAnalyse[]
  ausschreibungen         Ausschreibung[]
  offerten                Offerte[]
  versicherer             VersichererDB[]
  partner                 Partner[]
  partner_activities      PartnerActivity[]
  partner_documents       PartnerDocument[]
  claims                  Claim[]
  deals                   Deal[]
  verkaufschancen         Verkaufschance[]
  advisory_dossiers       AdvisoryDossier[]
  dossier_snapshots       DossierSnapshot[]
  mutation_requests       MutationRequest[]
  pricing_suggestions     PricingSuggestion[]
  email_campaigns         EmailCampaign[]
  email_templates         EmailTemplate[]
  interactions            Interaction[]
  insurance_knowledge_patterns InsuranceKnowledgePattern[]
  enterprise_improvements EnterpriseImprovement[]
  enterprise_incidents    EnterpriseIncident[]
  governance_rules        GovernanceRule[]
  governance_score_snapshots GovernanceScoreSnapshot[]
  duplicate_alerts        DuplicateAlert[]
  backuplogs              BackupLog[]
  errorlogs               ErrorLog[]
  extraction_correction_logs ExtractionCorrectionLog[]
  pdf_export_logs         PdfExportLog[]
  automation_queues       AutomationQueue[]
  ai_findings             AiFinding[]
  ai_reviews              AiReview[]
  contract_advisors       ContractAdvisor[]
  customer_advisors       CustomerAdvisor[]
  storno_configs          StornoConfig[]
  system_logs             SystemLog[]
  audit_logs              AuditLog[]
  commission_entries      CommissionEntry[]
  commission_rates_templates CommissionRate[]
  commission_splits       CommissionSplit[]

  @@map("organization")
}

// --------------------------------------------------------------------------
// 2. User
// --------------------------------------------------------------------------
model User {
  id                    String     @id @default(uuid())
  organization_id       String?
  role                  String     @default("broker")
  team_id               String?
  is_active             Boolean    @default(true)
  phone                 String?
  mobile                String?
  department            String?
  email                 String     @unique
  name                  String?
  password_hash         String?
  last_login            DateTime?
  reset_token_hash      String?
  reset_token_expires_at DateTime?
  created_at            DateTime   @default(now())
  updated_at            DateTime   @updatedAt
  archived              Boolean    @default(false)
  archived_at           DateTime?
  archived_by           String?

  // Relations
  organization           Organization?  @relation(fields: [organization_id], references: [id])
  customers_as_primary_advisor Customer[] @relation("PrimaryAdvisor")
  customers_as_advisor   Customer[]      @relation("AdvisorCustomers")
  contracts_as_primary_broker Contract[]  @relation("PrimaryBroker")
  tasks_assigned         Task[]          @relation("TaskAssignee")
  refresh_tokens         RefreshToken[]

  @@index([organization_id])
  @@map("user")
}

// --------------------------------------------------------------------------
// Refresh Token — secure token rotation for JWT refresh flow
// --------------------------------------------------------------------------
model RefreshToken {
  id              String    @id @default(uuid())
  token_hash      String
  user_id         String
  organization_id String?
  expires_at      DateTime
  revoked         Boolean   @default(false)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  // Relations
  user            User      @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([token_hash])
  @@map("refresh_token")
}

// --------------------------------------------------------------------------
// 3. Advisor
// --------------------------------------------------------------------------
model Advisor {
  id                String       @id @default(uuid())
  firstname         String
  lastname          String
  email             String
  phone             String?
  organization_id   String
  organization_name String?
  role              AdvisorRole  @default(advisor)
  status            String       @default("active")
  finma_number      String?
  vbv_number        String?
  total_commission  Float        @default(0)
  paid_commission   Float        @default(0)
